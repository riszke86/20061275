<%- include("partials/header", { pageTitle: "About Us" }) %>


<!-- ==========================================
     ABOUT PAGE HERO
========================================== -->

<section class="page-hero about-hero">

    <div class="page-hero-content">

        <p class="section-label">
            About Aquarium World
        </p>

        <h1>
            Connecting People With the Ocean
        </h1>

        <p>
            Aquarium World is an educational visitor attraction dedicated
            to marine discovery, conservation awareness and responsible
            animal care.
        </p>

    </div>

</section>


<!-- ==========================================
     OUR STORY
========================================== -->

<section class="about-story">

    <div class="about-section-container">

        <div class="about-text-content">

            <p class="section-label">
                Our Story
            </p>

            <h2>
                An underwater journey for every visitor
            </h2>

            <p>
                Aquarium World was created to help people understand the
                diversity and importance of aquatic environments. Our exhibits
                allow visitors to explore habitats ranging from colourful coral
                reefs to deep-sea ecosystems and tropical freshwater rivers.
            </p>

            <p>
                Through immersive displays, educational information and
                interactive experiences, we aim to make marine science
                engaging and accessible for visitors of all ages.
            </p>

        </div>


        <div class="about-image-placeholder">

            <p>
                Aquarium World image
            </p>

        </div>

    </div>

</section>


<!-- ==========================================
     OUR MISSION
========================================== -->

<section class="about-mission">

    <div class="section-heading">

        <p class="section-label">
            Our Mission
        </p>

        <h2>
            Education, conservation and responsible care
        </h2>

        <p class="section-introduction">
            Our work is guided by three core priorities that shape
            every exhibit, experience and visitor programme.
        </p>

    </div>


    <div class="mission-grid">

        <article class="mission-card">

            <p class="mission-number">
                01
            </p>

            <h3>
                Education
            </h3>

            <p>
                We make marine science understandable through exhibits,
                interpretation, talks and practical learning experiences.
            </p>

        </article>


        <article class="mission-card">

            <p class="mission-number">
                02
            </p>

            <h3>
                Conservation
            </h3>

            <p>
                We help visitors understand the environmental pressures
                affecting marine habitats and the actions people can take
                to protect them.
            </p>

        </article>


        <article class="mission-card">

            <p class="mission-number">
                03
            </p>

            <h3>
                Animal Welfare
            </h3>

            <p>
                We are committed to providing appropriate environments,
                specialist care and enrichment for every animal at
                Aquarium World.
            </p>

        </article>

    </div>

</section>


<!-- ==========================================
     CONSERVATION
========================================== -->

<section class="about-conservation">

    <div class="about-section-container reverse-layout">

        <div class="about-image-placeholder">

            <p>
                Marine conservation image
            </p>

        </div>


        <div class="about-text-content">

            <p class="section-label">
                Marine Conservation
            </p>

            <h2>
                Protecting aquatic environments
            </h2>

            <p>
                Oceans and freshwater habitats face significant challenges,
                including pollution, habitat loss, climate change and
                unsustainable fishing practices.
            </p>

            <p>
                Aquarium World supports conservation education by helping
                visitors understand these issues and encouraging practical,
                responsible choices.
            </p>

            <a href="/zones" class="button">
                Explore Our Exhibits
            </a>

        </div>

    </div>

</section>


<!-- ==========================================
     EDUCATION
========================================== -->

<section class="about-education">

    <div class="section-heading">

        <p class="section-label">
            Learning at Aquarium World
        </p>

        <h2>
            Inspiring future marine advocates
        </h2>

        <p class="section-introduction">
            Our educational approach combines observation, interpretation
            and interactive learning.
        </p>

    </div>


    <div class="education-grid">

        <article class="education-card">

            <h3>
                School Visits
            </h3>

            <p>
                Structured learning opportunities can support classroom
                topics including ecosystems, adaptation and sustainability.
            </p>

        </article>


        <article class="education-card">

            <h3>
                Family Learning
            </h3>

            <p>
                Clear interpretation and interactive exhibits help families
                explore marine science together.
            </p>

        </article>


        <article class="education-card">

            <h3>
                Daily Talks
            </h3>

            <p>
                Animal talks and feeding sessions provide additional
                information about behaviour, care and conservation.
            </p>

        </article>


        <article class="education-card">

            <h3>
                Digital Information
            </h3>

            <p>
                Online resources support visitors before and after their
                visit and make learning more accessible.
            </p>

        </article>

    </div>

</section>


<!-- ==========================================
     ANIMAL CARE
========================================== -->

<section class="animal-care-section">

    <div class="animal-care-content">

        <p class="section-label">
            Animal Care
        </p>

        <h2>
            Specialist care every day
        </h2>

        <p>
            Our aquarists monitor water conditions, animal health,
            nutrition and behaviour every day. Each habitat is managed
            according to the needs of the species living within it.
        </p>

        <p>
            Environmental enrichment, appropriate feeding programmes and
            regular observation form an important part of our welfare
            approach.
        </p>

    </div>

</section>


<!-- ==========================================
     VALUES
========================================== -->

<section class="about-values">

    <div class="section-heading">

        <p class="section-label">
            Our Values
        </p>

        <h2>
            What guides our work
        </h2>

    </div>


    <div class="values-grid">

        <article class="value-card">

            <h3>
                Responsibility
            </h3>

            <p>
                We take responsibility for animal welfare, environmental
                awareness and clear visitor information.
            </p>

        </article>


        <article class="value-card">

            <h3>
                Accessibility
            </h3>

            <p>
                We aim to make marine education understandable and welcoming
                for visitors with different needs and abilities.
            </p>

        </article>


        <article class="value-card">

            <h3>
                Curiosity
            </h3>

            <p>
                We encourage visitors to ask questions, explore habitats
                and develop a deeper interest in aquatic life.
            </p>

        </article>


        <article class="value-card">

            <h3>
                Conservation
            </h3>

            <p>
                We promote informed choices that support healthier oceans
                and freshwater environments.
            </p>

        </article>

    </div>

</section>


